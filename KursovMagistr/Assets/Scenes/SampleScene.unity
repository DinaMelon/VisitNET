  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u0412\u043E \u0432\u0440\u0435\u043C\u044F \u0421\u0442\u0430\u043B\u0438\u043D\u0433\u0440\u0430\u0434\u0441\u043A\u043E\u0439
    \u0431\u0438\u0442\u0432\u044B \u0437\u0434\u0430\u043D\u0438\u0435 \u0442\u0435\u0430\u0442\u0440\u0430
    \u0431\u044B\u043B\u043E \u0441\u0438\u043B\u044C\u043D\u043E \u043F\u043E\u0432\u0440\u0435\u0436\u0434\u0435\u043D\u043E.
    \u041F\u043E\u0437\u0434\u043D\u0435\u0435 \u0442\u0435\u0430\u0442\u0440 \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0438. 
    \n\u0421\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435 \u043B\u044C\u0432\u044B
    \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u044E\u0442, \u0447\u0442\u043E
