  m_Script: {fileID: 11500000, guid: 346c68833d15f7f45945cfd5a1efcbbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u0418\u0441\u0442\u043E\u0440\u0438\u044F \u044D\u0442\u043E\u0433\u043E
    \u043C\u0435\u0441\u0442\u0430 \u043D\u0430\u0447\u0430\u043B\u0430\u0441\u044C
    20 \u0434\u0435\u043A\u0430\u0431\u0440\u044F 1915 \u0433\u043E\u0434\u0430 \u0441
    \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0414\u043E\u043C\u0430 \u043D\u0430\u0443\u043A\u0438
    \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430.\n\u0417\u0434\u0430\u043D\u0438\u0435
    \u0438\u043C\u0435\u043B\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
    \u0437\u0430\u043B, \u0431\u0438\u0431\u043B\u0438\u043E\u0442\u0435\u043A\u0443,
    \u043C\u0443\u0437\u0435\u0439 \u0438 \u0443\u0447\u0435\u0431\u043D\u044B\u0435
    \u043A\u043B\u0430\u0441\u0441\u044B.\n\u041B\u0435\u0441\u0442\u043D\u0438\u0446\u0430
    \u043C\u0435\u0436\u0434\u0443 \u043B\u044C\u0432\u0430\u043C\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438
    \u0441\u043E\u0435\u0434\u0438\u043D\u044F\u0435\u0442 \u043F\u0440\u043E\u0448\u043B\u043E\u0435
    \u0438 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0435."
  image: {fileID: 21300000, guid: 468178667b9ec63408478c83a1151f3f, type: 3}
