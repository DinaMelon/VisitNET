  m_Script: {fileID: 11500000, guid: 346c68833d15f7f45945cfd5a1efcbbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u0417\u0430\u0434\u043D\u0438\u0439 \u0444\u0430\u0441\u0430\u0434
    \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442 \u0434\u0440\u0443\u0433\u0443\u044E,
    \u0440\u0430\u0431\u043E\u0447\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443
    \u0442\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u0436\u0438\u0437\u043D\u0438.
    \n\u042D\u0442\u0430 \u0447\u0430\u0441\u0442\u044C \u0437\u0434\u0430\u043D\u0438\u044F,
    \u0433\u0434\u0435 \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u044B
    \u0441\u043B\u0443\u0436\u0435\u0431\u043D\u044B\u0435 \u0432\u0445\u043E\u0434\u044B
    \u0438 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u0438\u0435, \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u0442
    \u043D\u0430\u043C, \u0447\u0442\u043E \u0432\u043E\u043B\u0448\u0435\u0431\u0441\u0442\u0432\u043E
    \u0441\u043F\u0435\u043A\u0442\u0430\u043A\u043B\u044F \u0440\u043E\u0436\u0434\u0430\u0435\u0442\u0441\u044F
    \u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u044F \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E\u043C\u0443
    \u0442\u0440\u0443\u0434\u0443."
  image: {fileID: 21300000, guid: 2131ad6640d239f49ade880385f2e916, type: 3}
