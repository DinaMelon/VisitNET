  m_Script: {fileID: 11500000, guid: 346c68833d15f7f45945cfd5a1efcbbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u041A\u043E\u043B\u043E\u043D\u043D\u044B \u0441\u043E\u0437\u0434\u0430\u044E\u0442
    \u043E\u0431\u0440\u0430\u0437 \u0443\u0441\u0442\u043E\u0439\u0447\u0438\u0432\u043E\u0441\u0442\u0438
    \u0438 \u0432\u0435\u043B\u0438\u0447\u0438\u044F.\n \n\u0422\u0430\u043A\u043E\u0439
    \u043F\u0440\u0438\u0435\u043C, \u0445\u0430\u0440\u0430\u043A\u0442\u0435\u0440\u043D\u044B\u0439
    \u0434\u043B\u044F \u043D\u0435\u043E\u043A\u043B\u0430\u0441\u0441\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0441\u0442\u0438\u043B\u044F \u0441\u0435\u0440\u0435\u0434\u0438\u043D\u044B
    20 \u0432\u0435\u043A\u0430, \u043E\u0442\u0441\u044B\u043B\u0430\u0435\u0442
    \u043D\u0430\u0441 \u043A \u043E\u0431\u0440\u0430\u0437\u0443 \u0438\u0441\u0442\u043E\u0440\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0437\u0434\u0430\u043D\u0438\u044F \u0442\u0435\u0430\u0442\u0440\u0430, \u0432\u043E\u0441\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u043E\u0433\u043E
    \u043F\u043E\u0441\u043B\u0435 \u0432\u043E\u0439\u043D\u044B.\n"
  image: {fileID: 21300000, guid: a41daf30ab35d964a96006aab8991ae4, type: 3}
