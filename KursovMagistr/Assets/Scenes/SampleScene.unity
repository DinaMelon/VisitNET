--- !u!114 &253405435
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 253405423}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 346c68833d15f7f45945cfd5a1efcbbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u0412 1988 \u0433\u043E\u0434\u0443 \u0441\u0442\u0430\u0440\u044B\u0439
    \u0434\u0440\u0430\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0442\u0435\u0430\u0442\u0440 \u0431\u044B\u043B \u0437\u0430\u043A\u0440\u044B\u0442.
    \n\n\u0411\u044B\u043B\u043E \u043F\u0440\u0438\u043D\u044F\u0442\u043E \u0440\u0435\u0448\u0435\u043D\u0438\u0435
    \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043D\u043E\u0432\u044B\u0439 \u0442\u0435\u0430\u0442\u0440,
    \u043F\u0440\u0438\u0433\u043B\u0430\u0441\u0438\u0432 \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0440\u0435\u0436\u0438\u0441\u0441\u0451\u0440\u0430 \u041E\u0442\u0430\u0440\u0430
    \u0414\u0436\u0430\u043D\u0433\u0438\u0448\u0435\u0440\u0430\u0448\u0432\u0438\u043B\u0438.
    \u0422\u0430\u043A \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F \u041D\u043E\u0432\u044B\u0439
    \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0430\u043B\u044C\u043D\u044B\u0439
    \u0442\u0435\u0430\u0442\u0440."
  image: {fileID: 21300000, guid: 893ed5035651a93429ab3f2ac1083007, type: 3}
