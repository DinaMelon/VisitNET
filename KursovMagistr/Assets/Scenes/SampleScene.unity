--- !u!114 &143000388
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 143000378}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 346c68833d15f7f45945cfd5a1efcbbc, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::InterestPoint
  fullInfo: "\u042D\u0442\u0438 \u0432\u0435\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435
    \u043B\u044C\u0432\u044B - \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u0443\u043A\u0440\u0430\u0448\u0435\u043D\u0438\u0435. \u0422\u0430\u043A\u0438\u0435
    \u0436\u0435 \u0441\u043A\u0443\u043B\u044C\u043F\u0442\u0443\u0440\u044B \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u043B\u0438
    \u0433\u043E\u0441\u0442\u0435\u0439 \u0443 \u0432\u0445\u043E\u0434\u0430 \u0432
    \u0414\u043E\u043C \u043D\u0430\u0443\u043A\u0438 \u0438 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430
    1915 \u0433\u043E\u0434\u0430.\n\u0412 \u0442\u0440\u0430\u0434\u0438\u0446\u0438\u043E\u043D\u043D\u043E\u0439
    \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0435 \u043B\u0435\u0432
    - \u0441\u0438\u043C\u0432\u043E\u043B \u0431\u043B\u0430\u0433\u043E\u0440\u043E\u0434\u0441\u0442\u0432\u0430,
    \u0437\u0430\u0449\u0438\u0442\u044B \u0438 \u0441\u0442\u0440\u0430\u0436 \u043F\u043E\u043A\u043E\u044F."
  image: {fileID: 21300000, guid: 26a84f92e8d3211409148e1a26e90426, type: 3}
