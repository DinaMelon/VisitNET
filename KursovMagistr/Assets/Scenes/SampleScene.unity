  fullInfo: "\u0424\u0438\u0433\u0443\u0440\u0430 \u0441 \u0430\u0440\u0444\u043E\u0439
    \u0432 \u0440\u0443\u043A\u0430\u0445 - \u044D\u0442\u043E \u041C\u0435\u043B\u044C\u043F\u043E\u043C\u0435\u043D\u0430,
    \u043C\u0443\u0437\u0430 \u0442\u0440\u0430\u0433\u0435\u0434\u0438\u0438. \n\u041E\u043D\u0430
    \u0431\u044B\u043B\u0430 \u0441\u0435\u0441\u0442\u0440\u043E\u0439 \u0434\u0440\u0443\u0433\u0438\u0445
    \u043C\u0443\u0437.\n\n\u041C\u0435\u043B\u044C\u043F\u043E\u043C\u0435\u043D\u0430
    \u043E\u043F\u0438\u0441\u044B\u0432\u0430\u0435\u0442\u0441\u044F \u043A\u0430\u043A
    \u043F\u043E\u044E\u0449\u0430\u044F \u043F\u0435\u0441\u043D\u0438 \u0441\u043A\u043E\u0440\u0431\u0438
    \u043F\u043E \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C \u043B\u044E\u0434\u044F\u043C
    \u043F\u043E\u0441\u043B\u0435 \u0438\u0445 \u0441\u043C\u0435\u0440\u0442\u0438,
    \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u043F\u043E \u043F\u043E\u044D\u0442\u0430\u043C."
